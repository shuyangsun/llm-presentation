{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash .agents/skills/vcs/scripts/cursor-hook.sh sessionStart",
        "timeout": 60,
        "failClosed": true
      }
    ],
    "beforeShellExecution": [
      {
        "command": "bash .agents/skills/vcs/scripts/cursor-hook.sh beforeShellExecution",
        "timeout": 30,
        "failClosed": true
      }
    ],
    "preToolUse": [
      {
        "command": "bash .agents/skills/vcs/scripts/cursor-hook.sh preToolUse",
        "matcher": "Shell|Write|Edit|Delete|Task",
        "timeout": 30,
        "failClosed": true
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash .agents/skills/vcs/scripts/cursor-hook.sh afterFileEdit",
        "timeout": 30,
        "failClosed": true
      }
    ]
  }
}
